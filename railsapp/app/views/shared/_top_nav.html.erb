<nav class="sticky top-0 z-50 border-b border-border bg-background/90 backdrop-blur"
     data-controller="mobile-menu">
  <div class="flex h-14 items-center justify-between">
    <div class="flex items-center gap-6">
      <span class="text-lg font-bold text-foreground">TimeReport</span>

      <div class="hidden items-center gap-1 md:flex">
        <%= link_to "Dashboard", dashboard_path,
              class: "relative rounded-md px-3 py-2 text-sm font-medium transition-colors #{ request.path == dashboard_path ? 'nav-active-top text-accent' : 'text-foreground-muted hover:text-foreground' }" %>
        <%= link_to "Projekt", projects_path,
              class: "relative rounded-md px-3 py-2 text-sm font-medium transition-colors #{ request.path.start_with?('/app/projects') ? 'nav-active-top text-accent' : 'text-foreground-muted hover:text-foreground' }" %>
        <%= link_to "Tasks", tasks_path,
              class: "relative rounded-md px-3 py-2 text-sm font-medium transition-colors #{ request.path.start_with?('/app/tasks') ? 'nav-active-top text-accent' : 'text-foreground-muted hover:text-foreground' }" %>
        <%= link_to "Noteringar", notes_path,
              class: "relative rounded-md px-3 py-2 text-sm font-medium transition-colors #{ request.path.start_with?('/app/notes') ? 'nav-active-top text-accent' : 'text-foreground-muted hover:text-foreground' }" %>
        <%= link_to "Exportera", export_time_entries_path,
              class: "relative rounded-md px-3 py-2 text-sm font-medium transition-colors #{ request.path.start_with?('/app/time_entries/export') ? 'nav-active-top text-accent' : 'text-foreground-muted hover:text-foreground' }" %>
        <%= link_to "Profil", edit_profile_path,
              class: "relative rounded-md px-3 py-2 text-sm font-medium transition-colors #{ request.path.start_with?('/app/profile') ? 'nav-active-top text-accent' : 'text-foreground-muted hover:text-foreground' }" %>
      </div>
    </div>

    <div class="flex items-center gap-2">
      <span class="hidden text-sm text-foreground-muted md:block"><%= current_user.email %></span>
      <%= button_to "Logga ut", logout_path, method: :delete,
            class: "hidden rounded-md px-3 py-1.5 text-sm text-foreground-muted hover:text-foreground md:block" %>

      <button type="button"
              class="rounded-md p-2 text-foreground-muted hover:text-foreground md:hidden"
              data-action="click->mobile-menu#toggle"
              aria-label="Meny">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <div class="hidden border-t border-border pb-3 pt-2 md:hidden" data-mobile-menu-target="menu">
    <div class="flex flex-col gap-1">
      <%= link_to "Dashboard", dashboard_path,
            class: "rounded-md px-3 py-2 text-sm font-medium text-foreground-muted hover:text-foreground" %>
      <%= link_to "Projekt", projects_path,
            class: "rounded-md px-3 py-2 text-sm font-medium text-foreground-muted hover:text-foreground" %>
      <%= link_to "Tasks", tasks_path,
            class: "rounded-md px-3 py-2 text-sm font-medium text-foreground-muted hover:text-foreground" %>
      <%= link_to "Noteringar", notes_path,
            class: "rounded-md px-3 py-2 text-sm font-medium text-foreground-muted hover:text-foreground" %>
      <%= link_to "Exportera", export_time_entries_path,
            class: "rounded-md px-3 py-2 text-sm font-medium text-foreground-muted hover:text-foreground" %>
      <%= link_to "Profil", edit_profile_path,
            class: "rounded-md px-3 py-2 text-sm font-medium text-foreground-muted hover:text-foreground" %>
      <div class="mt-2 border-t border-border pt-2">
        <span class="block px-3 py-1 text-xs text-foreground-muted"><%= current_user.email %></span>
        <%= button_to "Logga ut", logout_path, method: :delete,
              class: "w-full rounded-md px-3 py-2 text-left text-sm text-danger hover:text-danger-hover" %>
      </div>
    </div>
  </div>
</nav>
