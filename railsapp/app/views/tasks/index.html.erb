<div class="space-y-6">
  <div class="flex mb-4 items-center justify-between">
     <h1 class="text-xl font-bold text-foreground">Tasks</h1>
  </div>
</div>

<div class="space-y-6" data-controller="tabs">
  <div class="flex flex-wrap items-center gap-3">
    <%# New task form / button %>
    <%= turbo_frame_tag "task-form-frame" do %>
      <%= render "tasks/new_button" %>
    <% end %>

    <%= form_with url: tasks_path,
          method: :get,
          data: { turbo_action: "advance" },
          class: "order-last flex w-full min-w-0 items-center gap-2 sm:order-none sm:w-auto sm:flex-1 sm:max-w-md" do |f| %>
      <%= f.search_field :q,
            value: @query,
            placeholder: "Sök tasks...",
            class: "min-w-0 flex-1 rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder-foreground-muted focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent" %>
      <%= f.submit "Sök",
            class: "rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent-hover transition-colors cursor-pointer" %>
      <% if @query.present? %>
        <%= link_to "Rensa", tasks_path,
              class: "rounded-lg border border-border px-3 py-2 text-sm font-medium text-foreground-muted hover:text-foreground transition-colors" %>
      <% end %>
    <% end %>

    <%# Tabs %>
    <div class="ml-auto flex gap-1 rounded-lg border border-border bg-background-card p-1">
      <button type="button"
              class="rounded-md px-4 py-1.5 text-sm font-medium transition-colors bg-accent text-white"
              data-tabs-target="tab"
              data-action="click->tabs#show"
              data-tabs-panel="active-panel">
        Aktiva Tasks
      </button>
      <button type="button"
              class="rounded-md px-4 py-1.5 text-sm font-medium transition-colors text-foreground-muted hover:text-foreground"
              data-tabs-target="tab"
              data-action="click->tabs#show"
              data-tabs-panel="archived-panel">
        Arkiverade (<%= @archived_tasks.count %>)
      </button>
    </div>
  </div>

  <%# Active Tasks Panel %>
  <div id="active-panel" data-tabs-target="panel">

    <div id="active-tasks" class="mt-4 space-y-2">
      <% if @active_tasks.empty? %>
        <div class="rounded-xl border border-border bg-background-card p-8 text-center text-sm text-foreground-muted">
          <%= @query.present? ? "Inga aktiva tasks matchar sökningen." : "Inga aktiva tasks. Skapa din första task ovan." %>
        </div>
      <% else %>
        <% @active_tasks.each do |task| %>
          <%= render "tasks/task", task: task %>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# Archived Tasks Panel %>
  <div id="archived-panel" class="hidden" data-tabs-target="panel">
    <div id="archived-tasks" class="space-y-2">
      <% if @archived_tasks.empty? %>
        <div class="rounded-xl border border-border bg-background-card p-8 text-center text-sm text-foreground-muted">
          <%= @query.present? ? "Inga arkiverade tasks matchar sökningen." : "Inga arkiverade tasks." %>
        </div>
      <% else %>
        <% @archived_tasks.each do |task| %>
          <%= render "tasks/task", task: task %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
