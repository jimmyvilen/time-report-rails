<div class="rounded-xl border border-accent bg-background-card p-4"
     data-controller="task-form"
     data-task-form-jira-fetch-url-value="<%= jira_fetch_details_path %>">
  <%= form_with model: task, url: task.persisted? ? task_path(task) : tasks_path,
        method: task.persisted? ? :patch : :post,
        class: "space-y-3" do |f| %>

    <div class="grid grid-cols-1 gap-3">
      <div>
        <label class="mb-1 block text-xs font-medium text-foreground-muted">Titel *</label>
        <div class="flex gap-2">
          <%= f.text_field :title, required: true,
                placeholder: "Task-titel eller klistra in Jira-URL",
                class: "flex-1 rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder-foreground-muted focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent",
                data: { task_form_target: "title", action: "input->task-form#onTitleInput" } %>
          <button type="button"
                  class="hidden rounded-lg border border-border px-3 py-2 text-xs font-medium text-foreground-muted hover:border-accent hover:text-accent transition-colors"
                  data-task-form-target="fetchBtn"
                  data-action="click->task-form#fetchJira">
            Hämta från Jira
          </button>
        </div>
      </div>

      <div>
        <label class="mb-1 block text-xs font-medium text-foreground-muted">Jira-URL</label>
        <%= f.url_field :jira_url,
              placeholder: "https://your-org.atlassian.net/browse/PROJ-123",
              class: "w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder-foreground-muted focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent",
              data: { task_form_target: "jiraUrl" } %>
      </div>

      <% available_projects = local_assigns.fetch(:projects, []) %>
      <% if available_projects.any? %>
        <div>
          <label class="mb-1 block text-xs font-medium text-foreground-muted">Projekt</label>
          <%= f.select :project_id,
                options_for_select([["— Inget projekt —", ""]] + available_projects.map { |p| [p.name, p.id] }, task.project_id),
                { include_blank: false },
                class: "w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent" %>
        </div>
      <% end %>

      <div>
        <label class="mb-1 block text-xs font-medium text-foreground-muted">Beskrivning</label>
        <%= f.text_area :description, rows: 3,
              placeholder: "Valfri beskrivning",
              class: "w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder-foreground-muted focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent resize-none",
              data: { task_form_target: "description" } %>
      </div>
    </div>

    <div id="task-form-feedback" class="hidden text-sm"></div>

    <div class="flex justify-end gap-2">
      <%= link_to "Avbryt", tasks_path,
            class: "rounded-lg border border-border px-4 py-2 text-sm font-medium text-foreground-muted hover:text-foreground transition-colors",
            data: { turbo_frame: "task-form-frame" } %>
      <%= f.submit task.persisted? ? "Spara" : "Skapa task",
            class: "rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent-hover transition-colors cursor-pointer" %>
    </div>
  <% end %>
</div>
