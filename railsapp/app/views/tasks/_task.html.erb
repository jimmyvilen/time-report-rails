<%= turbo_frame_tag dom_id(task) do %>
  <% count = task.time_entries.count %>
  <% total_minutes = task.time_entries.sum(:duration_minutes) %>
  <div id="<%= dom_id(task) %>"
       class="card-glow group rounded-xl border border-border bg-background-card px-4 py-3 transition-colors hover:bg-background-card-hover mb-1.5">
    <div class="flex items-center gap-3">

      <%# Content %>
      <div class="min-w-0 flex-1">
        <div class="grid grid-cols-[minmax(0,1fr)_auto] items-start gap-3">
          <div class="min-w-0">
            <div class="flex items-center gap-2">
              <% if task.jira_url.present? %>
                <%= link_to "[#{task.jira_key}]", task.jira_url, target: "_blank", rel: "noopener",
                      class: "text-xs font-medium text-accent hover:underline" %>
              <% end %>
              <span class="text-sm font-medium text-foreground truncate"><%= task.title %></span>
              <% if task.project.present? %>
                <%= link_to task.project.name, project_path(task.project),
                      class: "rounded-full bg-accent/15 px-2 py-0.5 text-xs font-medium text-accent hover:bg-accent/25 transition-colors shrink-0" %>
              <% end %>
              <% if task.is_archived %>
                <span class="rounded-full bg-foreground-muted/20 px-2 py-0.5 text-xs text-foreground-muted">Arkiverad</span>
              <% end %>
            </div>
            <% if task.description.present? %>
              <p class="mt-0.5 text-xs text-foreground-muted line-clamp-2"><%= task.description %></p>
            <% end %>
          </div>

          <%# Actions & Duration %>
          <div class="flex shrink-0 items-center gap-3 text-right">

            <%# Actions %>
            <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
              <%# Favorite toggle %>
              <%= button_to favorite_task_path(task), method: :patch,
                    class: "rounded-lg p-1.5 transition-colors #{ task.is_favorite ? 'text-yellow-400 hover:text-yellow-500' : 'text-foreground-muted hover:text-yellow-400' }",
                    title: task.is_favorite ? "Ta bort favorit" : "Markera som favorit",
                    data: { turbo_confirm: false } do %>
                <svg class="h-4 w-4" fill="<%= task.is_favorite ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
                </svg>
              <% end %>

              <% if task.is_archived %>
                <%# Restore %>
                <%= button_to restore_task_path(task), method: :post,
                      class: "rounded-lg p-1.5 text-foreground-muted hover:text-success transition-colors",
                      title: "Återställ task",
                      data: { turbo_confirm: false } do %>
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                  </svg>
                <% end %>
              <% else %>
                <%# Edit %>
                <%= link_to edit_task_path(task),
                      class: "rounded-lg p-1.5 text-foreground-muted hover:text-foreground transition-colors",
                      title: "Redigera",
                      data: { turbo_frame: dom_id(task) } do %>
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                  </svg>
                <% end %>

                <%# Delete %>
                <%= button_to task_path(task), method: :delete,
                      class: "rounded-lg p-1.5 text-foreground-muted hover:text-danger transition-colors",
                      title: "Radera",
                      data: { turbo_confirm: "Är du säker? Tasken arkiveras om den har tidsrapporter." } do %>
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                  </svg>
                <% end %>
              <% end %>
            </div>

            <%# Duration %>
            <div class="w-20 text-right text-xs text-foreground-muted">
              <% if count > 0 %>
                <div class="tabular-nums"><%= total_minutes / 60 %>h <%= '%02d' % (total_minutes % 60) %>m</div>
                <div><%= count %> rapport<%= count == 1 ? "" : "er" %></div>
              <% end %>
            </div>

          </div>
        </div>
      </div>

    </div>
  </div>
<% end %>
