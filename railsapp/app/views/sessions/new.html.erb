<div class="flex min-h-screen items-center justify-center bg-background px-4">
  <div class="w-full max-w-sm">
    <div class="mb-8 text-center">
      <h1 class="text-2xl font-bold text-foreground">TimeReport</h1>
      <p class="mt-1 text-sm text-foreground-muted">Logga in för att fortsätta</p>
    </div>

    <div class="rounded-2xl border border-border bg-background-card p-6 shadow-sm">
      <%= render "shared/flash" %>

      <%= form_with url: login_path, method: :post, class: "space-y-4" do |f| %>
        <div>
          <label class="mb-1 block text-sm font-medium text-foreground" for="email">E-post</label>
          <%= f.email_field :email, id: "email",
                class: "w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder-foreground-muted focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent",
                placeholder: "din@epost.se",
                autocomplete: "email",
                required: true %>
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-foreground" for="password">Lösenord</label>
          <%= f.password_field :password, id: "password",
                class: "w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder-foreground-muted focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent",
                autocomplete: "current-password",
                required: true %>
        </div>
        <%= f.submit "Logga in",
              class: "w-full rounded-lg bg-accent px-4 py-2.5 text-sm font-medium text-white hover:bg-accent-hover focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 transition-colors cursor-pointer" %>
      <% end %>

      <div class="mt-4 text-center text-sm text-foreground-muted">
        Inget konto? <%= link_to "Registrera dig", register_path, class: "text-accent hover:underline" %>
      </div>
    </div>
  </div>
</div>
