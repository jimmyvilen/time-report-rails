<%= turbo_frame_tag dom_id(project) do %>
  <% task_count    = project.tasks.active.count %>
  <% total_minutes = project.total_minutes %>
  <div id="<%= dom_id(project) %>"
       class="card-glow group rounded-xl border border-border bg-background-card px-4 py-3 transition-colors hover:bg-background-card-hover mb-1.5">
    <div class="flex items-center gap-3">
      <div class="min-w-0 flex-1">
        <div class="flex flex-wrap items-start justify-between gap-2">
          <div class="min-w-0">
            <div class="flex items-center gap-2">
              <%= link_to project.name, project_path(project),
                    class: "text-sm font-medium text-foreground hover:text-accent transition-colors",
                    data: { turbo_frame: "_top" } %>
              <% if project.is_archived %>
                <span class="rounded-full bg-foreground-muted/20 px-2 py-0.5 text-xs text-foreground-muted">Arkiverat</span>
              <% end %>
            </div>
            <% if project.description.present? %>
              <p class="mt-0.5 text-xs text-foreground-muted line-clamp-2"><%= project.description %></p>
            <% end %>
          </div>

          <div class="flex shrink-0 items-center gap-3 text-right">
            <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
              <% if project.is_archived %>
                <%= button_to unarchive_project_path(project), method: :patch,
                      class: "rounded-lg p-1.5 text-foreground-muted hover:text-success transition-colors",
                      title: "Återställ projekt" do %>
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                  </svg>
                <% end %>
              <% else %>
                <%= link_to edit_project_path(project),
                      class: "rounded-lg p-1.5 text-foreground-muted hover:text-foreground transition-colors",
                      title: "Redigera",
                      data: { turbo_frame: dom_id(project) } do %>
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                  </svg>
                <% end %>
                <%= button_to archive_project_path(project), method: :patch,
                      class: "rounded-lg p-1.5 text-foreground-muted hover:text-foreground-muted transition-colors",
                      title: "Arkivera" do %>
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8l1 12a2 2 0 002 2h8a2 2 0 002-2L19 8m-9 4v6m4-6v6"/>
                  </svg>
                <% end %>
                <%= button_to project_path(project), method: :delete,
                      class: "rounded-lg p-1.5 text-foreground-muted hover:text-danger transition-colors",
                      title: "Radera",
                      data: { turbo_confirm: "Radera projektet? Kopplade tasks behålls men avkopplas från projektet." } do %>
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                  </svg>
                <% end %>
              <% end %>
            </div>

            <div class="w-20 text-right text-xs text-foreground-muted">
              <% if total_minutes > 0 %>
                <div class="tabular-nums"><%= total_minutes / 60 %>h <%= '%02d' % (total_minutes % 60) %>m</div>
              <% end %>
              <div><%= task_count %> task<%= task_count == 1 ? "" : "s" %></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>
