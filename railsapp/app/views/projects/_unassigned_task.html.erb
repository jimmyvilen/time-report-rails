<div id="unassigned-task-<%= task.id %>"
     class="group rounded-xl border border-border bg-background-card px-4 py-3 transition-colors hover:bg-background-card-hover mb-1.5 flex items-center justify-between">
  <div class="min-w-0 flex-1">
    <div class="flex items-center gap-2">
      <% if task.jira_url.present? %>
        <span class="text-xs font-medium text-foreground-muted shrink-0">[<%= task.jira_key %>]</span>
      <% end %>
      <span class="text-sm font-medium text-foreground truncate"><%= task.title %></span>
    </div>
  </div>
  <%= button_to add_task_project_path(project), method: :patch,
        params: { task_id: task.id },
        class: "ml-3 rounded-lg p-1.5 text-foreground-muted hover:text-accent transition-colors opacity-0 group-hover:opacity-100 shrink-0",
        title: "Lägg till i projekt" do %>
    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
    </svg>
  <% end %>
</div>
