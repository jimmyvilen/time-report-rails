<div id="project-task-<%= task.id %>"
     class="card-glow group rounded-xl border border-border bg-background-card px-4 py-3 transition-colors hover:bg-background-card-hover mb-1.5 flex items-center justify-between">
  <div class="min-w-0 flex-1">
    <div class="flex items-center gap-2">
      <% if task.jira_url.present? %>
        <%= link_to "[#{task.jira_key}]", task.jira_url, target: "_blank", rel: "noopener",
              class: "text-xs font-medium text-accent hover:underline shrink-0" %>
      <% end %>
      <span class="text-sm font-medium text-foreground truncate"><%= task.title %></span>
    </div>
    <% if task.description.present? %>
      <p class="mt-0.5 text-xs text-foreground-muted line-clamp-1"><%= task.description %></p>
    <% end %>
  </div>
  <div class="flex shrink-0 items-center gap-3 ml-3">
    <% total = task.time_entries.sum(:duration_minutes).to_i %>
    <% if total > 0 %>
      <span class="text-xs text-foreground-muted tabular-nums"><%= total / 60 %>h <%= '%02d' % (total % 60) %>m</span>
    <% end %>
    <%= button_to remove_task_project_path(project), method: :patch,
          params: { task_id: task.id },
          class: "rounded-lg p-1.5 text-foreground-muted hover:text-danger transition-colors opacity-0 group-hover:opacity-100",
          title: "Ta bort från projekt" do %>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    <% end %>
  </div>
</div>
