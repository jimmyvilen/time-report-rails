<div class="space-y-6" data-controller="tabs">
  <div class="flex items-center justify-between">
    <h1 class="text-xl font-bold text-foreground">Projekt</h1>
    <div class="flex gap-1 rounded-lg border border-border bg-background-card p-1">
      <button type="button"
              class="rounded-md px-4 py-1.5 text-sm font-medium transition-colors bg-accent text-white"
              data-tabs-target="tab"
              data-action="click->tabs#show"
              data-tabs-panel="active-panel">
        Aktiva
      </button>
      <button type="button"
              class="rounded-md px-4 py-1.5 text-sm font-medium transition-colors text-foreground-muted hover:text-foreground"
              data-tabs-target="tab"
              data-action="click->tabs#show"
              data-tabs-panel="archived-panel">
        Arkiverade (<%= @archived_projects.count %>)
      </button>
    </div>
  </div>

  <%= turbo_frame_tag "project-form-frame" do %>
    <%= render "projects/new_button" %>
  <% end %>

  <div id="active-panel" data-tabs-target="panel">
    <div id="active-projects" class="space-y-2">
      <% if @active_projects.empty? %>
        <div class="rounded-xl border border-border bg-background-card p-8 text-center text-sm text-foreground-muted">
          Inga aktiva projekt. Klicka på "+ Nytt projekt" för att komma igång.
        </div>
      <% else %>
        <% @active_projects.each do |project| %>
          <%= render "projects/project", project: project %>
        <% end %>
      <% end %>
    </div>
  </div>

  <div id="archived-panel" class="hidden" data-tabs-target="panel">
    <div id="archived-projects" class="space-y-2">
      <% if @archived_projects.empty? %>
        <div class="rounded-xl border border-border bg-background-card p-8 text-center text-sm text-foreground-muted">
          Inga arkiverade projekt.
        </div>
      <% else %>
        <% @archived_projects.each do |project| %>
          <%= render "projects/project", project: project %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
