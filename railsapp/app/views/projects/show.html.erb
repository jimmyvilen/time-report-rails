<div class="space-y-8">
  <div class="flex items-start justify-between gap-4">
    <div>
      <div class="mb-1">
        <%= link_to "← Alla projekt", projects_path,
              class: "text-sm text-foreground-muted hover:text-accent transition-colors" %>
      </div>
      <h1 class="text-xl font-bold text-foreground"><%= @project.name %></h1>
      <% if @project.description.present? %>
        <p class="mt-1 text-sm text-foreground-muted"><%= @project.description %></p>
      <% end %>
    </div>
    <div class="text-right shrink-0">
      <% if @total_minutes > 0 %>
        <div class="tabular-nums text-lg font-semibold text-foreground">
          <%= @total_minutes / 60 %>h <%= '%02d' % (@total_minutes % 60) %>m
        </div>
        <div class="text-xs text-foreground-muted">totalt</div>
      <% end %>
    </div>
  </div>

  <div>
    <h2 class="mb-3 text-sm font-medium text-foreground">Tasks i projektet (<%= @tasks.count %>)</h2>
    <div id="project-tasks" class="space-y-1">
      <% if @tasks.empty? %>
        <div class="rounded-xl border border-border bg-background-card p-6 text-center text-sm text-foreground-muted">
          Inga tasks kopplade ännu. Lägg till tasks från listan nedan.
        </div>
      <% else %>
        <% @tasks.each do |task| %>
          <%= render "projects/project_task", task: task, project: @project %>
        <% end %>
      <% end %>
    </div>
  </div>

  <% unless @unassigned_tasks.empty? %>
    <div>
      <h2 class="mb-3 text-sm font-medium text-foreground">Tillgängliga tasks utan projekt (<%= @unassigned_tasks.count %>)</h2>
      <div id="unassigned-tasks" class="space-y-1">
        <% @unassigned_tasks.each do |task| %>
          <%= render "projects/unassigned_task", task: task, project: @project %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
