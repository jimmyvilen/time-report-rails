<h1 class="mb-8 text-xl font-semibold text-foreground">Exportera</h1>

<div class="divide-y divide-border">
  <div class="pb-8">
    <h2 class="mb-1 text-sm font-medium text-foreground">Tidsrapport</h2>
    <p class="mb-4 text-sm text-foreground-muted">Exportera tidrapportsposter som CSV</p>
    <%= form_with url: export_time_entries_path, method: :get, data: { turbo: false }, class: "flex flex-wrap items-end gap-3" do |f| %>
      <div class="flex flex-col gap-1">
        <%= label_tag :from, "Från", class: "text-xs text-foreground-muted" %>
        <%= date_field_tag :from, @from, required: true,
              class: "rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground focus:border-accent focus:outline-none" %>
      </div>
      <div class="flex flex-col gap-1">
        <%= label_tag :to, "Till", class: "text-xs text-foreground-muted" %>
        <%= date_field_tag :to, @to, required: true,
              class: "rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground focus:border-accent focus:outline-none" %>
      </div>
      <button type="submit"
              class="inline-flex items-center gap-2 rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent-hover transition-colors">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
        Ladda ner CSV
      </button>
    <% end %>
  </div>

  <div class="pt-8">
    <h2 class="mb-1 text-sm font-medium text-foreground">Noteringar</h2>
    <p class="mb-4 text-sm text-foreground-muted">Exportera dagliga noteringar som CSV</p>
    <%= form_with url: export_notes_path, method: :get, data: { turbo: false }, class: "flex flex-wrap items-end gap-3" do |f| %>
      <div class="flex flex-col gap-1">
        <%= label_tag :from, "Från", class: "text-xs text-foreground-muted" %>
        <%= date_field_tag :from, @from, required: true,
              class: "rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground focus:border-accent focus:outline-none" %>
      </div>
      <div class="flex flex-col gap-1">
        <%= label_tag :to, "Till", class: "text-xs text-foreground-muted" %>
        <%= date_field_tag :to, @to, required: true,
              class: "rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground focus:border-accent focus:outline-none" %>
      </div>
      <button type="submit"
              class="inline-flex items-center gap-2 rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent-hover transition-colors">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
        Ladda ner CSV
      </button>
    <% end %>
  </div>
</div>
