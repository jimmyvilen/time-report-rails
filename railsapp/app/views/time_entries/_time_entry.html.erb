<%= turbo_frame_tag dom_id(entry) do %>
  <div id="<%= dom_id(entry) %>"
       class="card-glow group relative rounded-xl border border-border bg-background-card transition-colors hover:bg-background-card-hover mb-1.5"
       data-entry-id="<%= entry.id %>">
    <div class="flex items-start gap-3 px-4 py-3">
      <%# Drag handle %>
      <div class="mt-0.5 cursor-grab touch-none text-foreground-muted opacity-0 group-hover:opacity-100 transition-opacity"
           data-sortable-handle>
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M8 6a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm0 6a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm0 6a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm8-12a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm0 6a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm0 6a2 2 0 1 1-4 0 2 2 0 0 1 4 0z"/>
        </svg>
      </div>

      <%# Main content %>
      <div class="min-w-0 flex-1">
        <div class="grid grid-cols-[minmax(0,1fr)_auto] items-start gap-3">
          <div class="min-w-0">
            <%# Task name %>
            <div class="flex min-w-0 items-center gap-1.5">
              <% if entry.task.jira_url.present? %>
                <span class="shrink-0 text-xs font-medium text-accent">[<%= entry.task.jira_key %>]</span>
              <% end %>
              <span class="text-sm font-medium text-foreground truncate"><%= entry.task.title %></span>
            </div>
            <%# Description %>
            <% if entry.description.present? %>
              <p class="mt-0.5 break-words text-sm text-foreground-muted line-clamp-2"><%= entry.description %></p>
            <% end %>
          </div>

          <%# Actions % Durations %>
          <div class="flex shrink-0 items-center gap-3 text-right">

            <%# Actions %>
            <div class="flex items-center gap-1">
              <%# Push to Jira %>
              <% if entry.task.jira_url.present? %>
                <% if entry.pushed? %>
                  <span title="Skickad till Jira <%= entry.pushed_at&.strftime('%Y-%m-%d %H:%M') %>"
                        class="rounded-lg p-1.5 text-success cursor-default">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                  </span>
                <% elsif entry.can_push_to_jira? %>
                  <%= button_to push_to_jira_time_entry_path(entry), method: :post,
                        class: "rounded-lg p-1.5 text-foreground-muted hover:text-accent transition-colors",
                        title: "Skicka till Jira" do %>
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
                    </svg>
                  <% end %>
                <% else %>
                  <span title="Saknar start/sluttid eller varaktighet för att skicka till Jira"
                        class="rounded-lg p-1.5 text-foreground-muted/40 cursor-not-allowed">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
                    </svg>
                  </span>
                <% end %>
              <% end %>

              <%# Duplicate %>
              <%= button_to duplicate_time_entry_path(entry), method: :post,
                    class: "rounded-lg p-1.5 text-foreground-muted hover:text-foreground transition-colors",
                    title: "Duplicera" do %>
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                </svg>
              <% end %>

              <%# Edit %>
              <%= link_to edit_time_entry_path(entry),
                    class: "rounded-lg p-1.5 text-foreground-muted hover:text-foreground transition-colors",
                    title: "Redigera",
                    data: { turbo_frame: dom_id(entry) } do %>
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
              <% end %>

              <%# Delete %>
              <%= button_to time_entry_path(entry), method: :delete,
                    class: "rounded-lg p-1.5 text-foreground-muted hover:text-danger transition-colors",
                    title: "Radera",
                    data: { turbo_confirm: "Är du säker på att du vill radera denna tidsrapport?" } do %>
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
              <% end %>
            </div>

            <%# Duration & Time %>
            <% minutes = entry.effective_duration_minutes.to_i %>
            <div class="w-20">
              <div class="text-sm font-semibold text-foreground text-right">
                <%= minutes > 0 ? format_duration(minutes) : "" %>
              </div>
              <div class="text-xs text-foreground-muted text-right">
                <% if entry.start_time && entry.end_time %>
                  <%= entry.start_time.strftime("%H:%M") %>–<%= entry.end_time.strftime("%H:%M") %>
                <% elsif entry.start_time %>
                  <%= entry.start_time.strftime("%H:%M") %>–
                <% else %>
                  &nbsp;
                <% end %>
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>
