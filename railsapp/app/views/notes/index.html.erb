<h1 class="mb-8 text-xl font-semibold text-foreground">Noteringar</h1>

<div class="divide-y divide-border">
  <div class="pb-8">
    <h2 class="mb-1 text-sm font-medium text-foreground">Sök</h2>
    <p class="mb-4 text-sm text-foreground-muted">Hitta tidigare dagliga noteringar</p>

    <%= turbo_frame_tag "notes-search" do %>
      <%= form_with url: notes_path, method: :get, data: { turbo_frame: "notes-list", turbo_action: "advance" }, class: "flex max-w-sm gap-2" do |f| %>
        <%= f.search_field :q, value: @query,
              placeholder: "Sök noteringar...",
              class: "min-w-0 flex-1 rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder-foreground-muted focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent" %>
        <%= f.submit "Sök",
              class: "rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent-hover transition-colors cursor-pointer" %>
      <% end %>
    <% end %>
  </div>

  <div class="pt-8">
    <%= turbo_frame_tag "notes-list" do %>
      <h2 class="mb-1 text-sm font-medium text-foreground">Dagliga noteringar</h2>
      <p class="mb-4 text-sm text-foreground-muted">
        <%= @total_count == 1 ? "1 notering" : "#{@total_count} noteringar" %>
      </p>

      <% if @notes.empty? %>
        <div class="rounded-lg border border-border bg-background-elevated p-6 text-sm text-foreground-muted">
          <%= @query.present? ? "Inga noteringar matchar sökningen." : "Inga noteringar än." %>
        </div>
      <% else %>
        <div class="divide-y divide-border">
          <% @notes.each do |note| %>
            <article class="py-5 first:pt-0">
              <div class="mb-3 flex items-center justify-between gap-3">
                <time datetime="<%= note.date %>" class="text-xs font-medium text-accent"><%= note.date %></time>
                <%= link_to dashboard_path(date: note.date),
                      class: "shrink-0 rounded-lg p-1.5 text-foreground-muted hover:text-foreground transition-colors",
                      title: "Öppna i dashboard",
                      data: { turbo_frame: "_top" } do %>
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                <% end %>
              </div>

              <div class="prose-content text-sm text-foreground">
                <%= render_markdown(note.content) %>
              </div>
            </article>
          <% end %>
        </div>

        <% if @total_pages > 1 %>
          <% query_params = @query.present? ? { q: @query } : {} %>
          <nav class="mt-4 flex items-center justify-between gap-3 border-t border-border pt-4 text-sm" aria-label="Sidnavigering">
            <div class="text-foreground-muted">
              Sida <%= @page %> av <%= @total_pages %>
            </div>

            <div class="flex items-center gap-2">
              <% if @page > 1 %>
                <%= link_to "Föregående",
                      notes_path(query_params.merge(page: @page - 1)),
                      class: "rounded-lg border border-border px-3 py-2 text-foreground-muted hover:text-foreground transition-colors",
                      data: { turbo_frame: "notes-list", turbo_action: "advance" } %>
              <% else %>
                <span class="cursor-not-allowed rounded-lg border border-border px-3 py-2 text-foreground-muted/40">Föregående</span>
              <% end %>

              <% if @page < @total_pages %>
                <%= link_to "Nästa",
                      notes_path(query_params.merge(page: @page + 1)),
                      class: "rounded-lg border border-border px-3 py-2 text-foreground-muted hover:text-foreground transition-colors",
                      data: { turbo_frame: "notes-list", turbo_action: "advance" } %>
              <% else %>
                <span class="cursor-not-allowed rounded-lg border border-border px-3 py-2 text-foreground-muted/40">Nästa</span>
              <% end %>
            </div>
          </nav>
        <% end %>
      <% end %>
    <% end %>
  </div>
</div>
