<h1 class="mb-8 text-xl font-semibold text-foreground">Profil</h1>

<%= form_with model: @user, url: profile_path, method: :patch do |f| %>
  <div class="divide-y divide-border">

    <div class="pb-8">
      <h2 class="mb-1 text-sm font-medium text-foreground">Kontoinformation</h2>
      <p class="mb-4 text-sm text-foreground-muted">Ditt namn och din inloggning</p>
      <div class="flex flex-col gap-3 max-w-sm">
        <div>
          <label class="mb-1 block text-xs text-foreground-muted">E-post</label>
          <div class="rounded-lg border border-border bg-background-elevated px-3 py-2 text-sm text-foreground-muted">
            <%= @user.email %>
          </div>
        </div>
        <div>
          <label class="mb-1 block text-xs text-foreground-muted">Namn</label>
          <%= f.text_field :name,
                class: "w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder-foreground-muted focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent",
                placeholder: "Ditt namn" %>
        </div>
      </div>
    </div>

    <div class="py-8">
      <h2 class="mb-1 text-sm font-medium text-foreground">Byt lösenord</h2>
      <p class="mb-4 text-sm text-foreground-muted">Lämna tomt för att behålla befintligt lösenord</p>
      <div class="flex flex-col gap-3 max-w-sm">
        <div>
          <label class="mb-1 block text-xs text-foreground-muted">Nytt lösenord</label>
          <%= f.password_field :password,
                class: "w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent",
                placeholder: "Nytt lösenord" %>
        </div>
        <div>
          <label class="mb-1 block text-xs text-foreground-muted">Bekräfta lösenord</label>
          <%= f.password_field :password_confirmation,
                class: "w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent" %>
        </div>
      </div>
    </div>

    <div class="py-8">
      <h2 class="mb-1 text-sm font-medium text-foreground">Jira-integration</h2>
      <p class="mb-4 text-sm text-foreground-muted">Anslut ditt Jira-konto för att logga tid direkt från appen</p>
      <div class="flex flex-col gap-3 max-w-sm">
        <div>
          <label class="mb-1 block text-xs text-foreground-muted">Jira-URL</label>
          <%= f.url_field :jira_url,
                class: "w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder-foreground-muted focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent",
                placeholder: "https://your-org.atlassian.net" %>
        </div>
        <div>
          <label class="mb-1 block text-xs text-foreground-muted">Jira-e-post</label>
          <%= f.email_field :jira_email,
                class: "w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder-foreground-muted focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent",
                placeholder: "din@epost.se" %>
        </div>
        <div>
          <label class="mb-1 block text-xs text-foreground-muted">API-token</label>
          <%= f.password_field :jira_api_token,
                class: "w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent",
                placeholder: "Din Jira API-token",
                autocomplete: "off" %>
          <p class="mt-1.5 text-xs text-foreground-muted">
            Skapa en API-token på
            <a href="https://id.atlassian.com/manage/api-tokens" target="_blank" rel="noopener"
               class="text-accent hover:underline">id.atlassian.com</a>
          </p>
        </div>
      </div>
    </div>

  </div>

  <div class="pt-2">
    <%= f.submit "Spara ändringar",
          class: "rounded-lg bg-accent px-6 py-2.5 text-sm font-medium text-white hover:bg-accent-hover transition-colors cursor-pointer" %>
  </div>
<% end %>
