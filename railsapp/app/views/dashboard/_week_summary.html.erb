<aside id="week-summary" class="w-full shrink-0 lg:w-72">
  <div class="rounded-2xl border border-border bg-background-card p-4">
    <div class="mb-3 flex items-center justify-between">
      <span class="text-xs font-semibold uppercase tracking-wide text-foreground-muted">Vecka <%= week_number %></span>
      <span class="text-xs text-foreground-muted"><%= format_duration(week_total) %> totalt</span>
    </div>
    <div class="space-y-1">
      <% weekly_days.each do |day| %>
        <% is_selected = day[:date] == selected_date %>
        <%= link_to dashboard_path(date: day[:date]),
              data: { turbo_frame: "dashboard-frame" },
              class: "flex items-center justify-between rounded-lg px-3 py-2 text-sm transition-colors #{ is_selected ? 'bg-accent/10 text-accent' : 'text-foreground-muted hover:bg-background-card-hover hover:text-foreground' }" do %>
          <div class="flex items-center gap-2">
            <span class="w-24 capitalize font-medium"><%= day[:day_name] %></span>
            <% if day[:first_start] && day[:last_end] %>
              <span class="text-xs text-foreground-muted"><%= day[:first_start] %>–<%= day[:last_end] %></span>
            <% end %>
          </div>
          <span class="<%= day[:total_minutes].to_i > 0 ? 'text-foreground' : 'text-foreground-muted' %>">
            <%= day[:total_minutes].to_i > 0 ? format_duration(day[:total_minutes]) : "–" %>
          </span>
        <% end %>
      <% end %>
    </div>
  </div>
</aside>
