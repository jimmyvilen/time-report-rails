<div data-controller="note-panel">
  <%# Toggle button — sits in the button row %>
  <button type="button"
          class="flex items-center gap-2 rounded-lg border border-border px-3 py-2 text-sm text-foreground-muted hover:border-accent hover:text-foreground transition-colors"
          data-action="click->note-panel#toggle">
    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
    </svg>
    <span>
      <% if note&.content.present? %>
        Notering ·
        <span class="text-xs text-foreground-muted truncate max-w-48 inline-block align-bottom">
          <%= note.content.lines.first&.strip&.truncate(60) %>
        </span>
      <% else %>
        Lägg till notering
      <% end %>
    </span>
  </button>

  <%# Editor panel — full width, rendered outside the flex row via a portal-like w-full wrapper %>
  <div class="hidden" data-note-panel-target="panel">
    <div class="mt-3 rounded-xl border border-border bg-background-card p-4">
      <%= form_with url: daily_note_path(date),
            method: note&.persisted? ? :patch : :post,
            data: { controller: "markdown-editor", turbo_frame: "_top" },
            class: "space-y-3" do |f| %>
        <%= hidden_field_tag "daily_note[date]", date %>

        <textarea name="daily_note[content]"
                  placeholder="Skriv din dagliga notering här... (Markdown stöds)"
                  rows="6"
                  class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder-foreground-muted focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent resize-none"
                  data-markdown-editor-target="textarea"><%= note&.content %></textarea>

        <div class="flex justify-end gap-2">
          <button type="button"
                  class="rounded-lg border border-border px-4 py-2 text-sm font-medium text-foreground-muted hover:text-foreground transition-colors"
                  data-action="click->note-panel#toggle">
            Stäng
          </button>
          <button type="submit"
                  class="rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent-hover transition-colors">
            Spara
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>
