<%= turbo_frame_tag dom_id(@entry) do %>
  <% jira_sync = @jira_sync_snapshot || {
    pushed: (@entry.pushed? || @entry.jira_worklog_id.present?),
    jira_worklog_id: @entry.jira_worklog_id,
    task_id: @entry.task_id,
    start_time_value: @entry.start_time&.strftime("%H:%M"),
    effective_duration_minutes: @entry.effective_duration_minutes.to_i
  } %>
  <div class="rounded-xl border border-accent bg-background-card p-4"
       data-controller="time-entry-form"
       data-time-entry-form-original-pushed-value="<%= jira_sync[:pushed].to_s %>"
       data-time-entry-form-original-jira-worklog-id-value="<%= jira_sync[:jira_worklog_id] %>"
       data-time-entry-form-original-task-id-value="<%= jira_sync[:task_id] %>"
       data-time-entry-form-original-start-time-value="<%= jira_sync[:start_time_value] %>"
       data-time-entry-form-original-effective-duration-minutes-value="<%= jira_sync[:effective_duration_minutes] %>">
    <h3 class="mb-3 text-sm font-medium text-foreground">Redigera tidsrapport</h3>
    <%= form_with model: @entry, url: time_entry_path(@entry), method: :patch,
          class: "space-y-3",
          data: { turbo_frame: dom_id(@entry), action: "submit->time-entry-form#confirmJiraReset" } do |f| %>
      <input type="hidden" name="time_entry[delete_jira_worklog]" value=""
             data-time-entry-form-target="deleteJiraWorklog" />
      <%= render "time_entries/form_errors", entry: @entry %>

      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        <div class="sm:col-span-2">
          <label class="mb-1 block text-xs font-medium text-foreground-muted">Task</label>
          <div class="relative"
               data-controller="task-selector"
               data-task-selector-tasks-value="<%= html_escape(@tasks.map { |t| { id: t.id, title: t.title, jira_key: t.jira_key, jira_url: t.jira_url } }.to_json) %>"
               data-task-selector-create-url-value="<%= tasks_path %>"
               data-task-selector-jira-fetch-url-value="<%= jira_fetch_details_path %>">
            <% current_task = @tasks.find { |t| t.id == @entry.task_id } %>
            <input type="text"
                   value="<%= current_task ? (current_task.jira_key ? "[#{current_task.jira_key}] #{current_task.title}" : current_task.title) : "" %>"
                   placeholder="Sök eller klistra in Jira-länk…"
                   autocomplete="off"
                   class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder-foreground-muted focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
                   data-task-selector-target="input"
                   data-action="focus->task-selector#onFocus input->task-selector#onInput" />
            <input type="hidden" name="time_entry[task_id]" required
                   value="<%= @entry.task_id %>"
                   data-task-selector-target="hidden"
                   data-time-entry-form-target="taskSelect"
                   data-action="change->time-entry-form#onTaskChange" />
            <div class="absolute z-10 w-full mt-1 hidden rounded-xl border border-border bg-background-card shadow-lg max-h-60 overflow-auto"
                 data-task-selector-target="dropdown">
              <ul data-task-selector-target="list"></ul>
            </div>
          </div>
        </div>

        <div class="sm:col-span-2">
          <label class="mb-1 block text-xs font-medium text-foreground-muted">Varaktighet</label>
          <input type="text" name="time_entry[duration]"
                 value="<%= @entry.duration_minutes ? "#{@entry.duration_minutes}m" : '' %>"
                 placeholder="t.ex. 1h 30m"
                 class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder-foreground-muted focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
                 data-time-entry-form-target="duration" />
        </div>

        <div>
          <label class="mb-1 block text-xs font-medium text-foreground-muted">Starttid</label>
          <input type="text" name="time_entry[start_time]"
                 value="<%= @entry.start_time&.strftime('%H:%M') %>"
                 placeholder="HH:MM" maxlength="5"
                 class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder-foreground-muted focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
                 data-controller="time-input"
                 data-time-entry-form-target="startTime"
                 data-action="blur->time-entry-form#onStartTimeChange" />
        </div>

        <div>
          <label class="mb-1 block text-xs font-medium text-foreground-muted">Sluttid</label>
          <input type="text" name="time_entry[end_time]"
                 value="<%= @entry.end_time&.strftime('%H:%M') %>"
                 placeholder="HH:MM" maxlength="5"
                 class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder-foreground-muted focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
                 data-controller="time-input"
                 data-time-entry-form-target="endTime"
                 data-action="blur->time-entry-form#onEndTimeChange" />
        </div>

        <div class="sm:col-span-2">
          <label class="mb-1 block text-xs font-medium text-foreground-muted">Beskrivning</label>
          <input type="text" name="time_entry[description]"
                 value="<%= @entry.description %>"
                 placeholder="Vad jobbade du med?"
                 class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder-foreground-muted focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent" />
        </div>
      </div>

      <div class="flex justify-end gap-2 pt-1">
        <%= link_to "Avbryt", dashboard_path(date: @entry.date),
              class: "rounded-lg border border-border px-4 py-2 text-sm font-medium text-foreground-muted hover:text-foreground transition-colors",
              data: { turbo_frame: dom_id(@entry) } %>
        <%= f.submit "Spara",
              class: "rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent-hover transition-colors cursor-pointer" %>
      </div>

      <div class="hidden fixed inset-0 z-[100] flex items-center justify-center bg-black/50 px-4 py-6"
           data-time-entry-form-target="jiraResetModal"
           role="dialog"
           aria-modal="true"
           aria-labelledby="jira-reset-title">
        <div class="w-full max-w-md rounded-xl border border-border bg-background-card p-5 shadow-2xl">
          <div class="flex items-start gap-3">
            <div class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-danger/10 text-danger">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v4m0 4h.01M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
              </svg>
            </div>
            <div class="min-w-0 flex-1">
              <h3 id="jira-reset-title" class="text-sm font-semibold text-foreground">Radera gammal Jira-tid?</h3>
              <p class="mt-1 text-sm leading-5 text-foreground-muted">
                Den här tidsrapporten är redan skickad till Jira. Vill du radera den gamla Jira-registreringen innan ändringen sparas?
              </p>
            </div>
            <button type="button"
                    class="rounded-lg p-1.5 text-foreground-muted hover:text-foreground transition-colors"
                    title="Stäng"
                    data-action="click->time-entry-form#closeJiraResetModal">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18 18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>

          <div class="mt-4 rounded-lg border border-border bg-background px-3 py-2 text-xs leading-5 text-foreground-muted">
            Posten markeras som ej skickad lokalt oavsett val, så du kan ladda upp den igen med den nya tasken eller tiden.
          </div>

          <div class="mt-5 flex flex-col-reverse gap-2 sm:flex-row sm:justify-end">
            <button type="button"
                    class="rounded-lg border border-border px-4 py-2 text-sm font-medium text-foreground-muted hover:text-foreground transition-colors"
                    data-action="click->time-entry-form#keepJiraWorklog">
              Behåll i Jira
            </button>
            <button type="button"
                    class="rounded-lg bg-danger px-4 py-2 text-sm font-medium text-white hover:bg-danger-hover transition-colors"
                    data-jira-reset-primary
                    data-action="click->time-entry-form#deleteJiraWorklog">
              Radera i Jira
            </button>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
