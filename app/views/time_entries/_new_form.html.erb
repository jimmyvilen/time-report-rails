<% visible = local_assigns.fetch(:visible, entry.errors.any?) %>
<div id="new-entry-form"
     class="<%= [("hidden" unless visible), "mt-3 rounded-xl border border-border bg-background-card p-4"].compact.join(" ") %>"
     data-time-entry-form-target="formPanel">

  <%= form_with url: time_entries_path, method: :post,
        class: "space-y-3" do |f| %>
    <input type="hidden" name="time_entry[date]" value="<%= date %>">

    <%= render "time_entries/form_errors", entry: entry %>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="sm:col-span-2">
        <label class="mb-1 block text-xs font-medium text-foreground-muted">Task</label>
        <div class="relative"
             data-controller="task-selector"
             data-task-selector-tasks-value="<%= html_escape(tasks.map { |t| { id: t.id, title: t.title, jira_key: t.jira_key, jira_url: t.jira_url } }.to_json) %>"
             data-task-selector-create-url-value="<%= tasks_path %>"
             data-task-selector-jira-fetch-url-value="<%= jira_fetch_details_path %>">
          <input type="text"
                 placeholder="Sök eller klistra in Jira-länk…"
                 autocomplete="off"
                 class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder-foreground-muted focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
                 data-task-selector-target="input"
                 data-action="focus->task-selector#onFocus input->task-selector#onInput" />
          <input type="hidden" name="time_entry[task_id]" required
                 data-task-selector-target="hidden"
                 data-time-entry-form-target="taskSelect"
                 data-action="change->time-entry-form#onTaskChange" />
          <div class="absolute z-10 w-full mt-1 hidden rounded-xl border border-border bg-background-card shadow-lg max-h-60 overflow-auto"
               data-task-selector-target="dropdown">
            <ul data-task-selector-target="list"></ul>
          </div>
        </div>
      </div>

      <div class="sm:col-span-2">
        <label class="mb-1 block text-xs font-medium text-foreground-muted">Varaktighet (t.ex. 1.5h, 30m)</label>
        <input type="text" name="time_entry[duration]" placeholder="t.ex. 1h 30m"
               class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder-foreground-muted focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
               data-time-entry-form-target="duration" />
      </div>

      <div>
        <label class="mb-1 block text-xs font-medium text-foreground-muted">Starttid</label>
        <input type="text" name="time_entry[start_time]" placeholder="HH:MM"
               maxlength="5"
               class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder-foreground-muted focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
               data-controller="time-input"
               data-time-entry-form-target="startTime"
               data-action="blur->time-entry-form#onStartTimeChange" />
      </div>

      <div>
        <label class="mb-1 block text-xs font-medium text-foreground-muted">Sluttid</label>
        <input type="text" name="time_entry[end_time]" placeholder="HH:MM"
               maxlength="5"
               class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder-foreground-muted focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
               data-controller="time-input"
               data-time-entry-form-target="endTime"
               data-action="blur->time-entry-form#onEndTimeChange" />
      </div>

      <div class="sm:col-span-2">
        <label class="mb-1 block text-xs font-medium text-foreground-muted">Beskrivning</label>
        <input type="text" name="time_entry[description]" placeholder="Vad jobbade du med?"
               class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder-foreground-muted focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
               data-time-entry-form-target="description" />
      </div>
    </div>

    <div class="flex justify-end gap-2 pt-1">
      <button type="button"
              class="rounded-lg border border-border px-4 py-2 text-sm font-medium text-foreground-muted hover:text-foreground transition-colors"
              data-action="click->time-entry-form#toggle">
        Avbryt
      </button>
      <%= f.submit "Lägg till",
            class: "rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent-hover transition-colors cursor-pointer" %>
    </div>
  <% end %>
</div>
